# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Optional overrides ───────────────────────────────────────────────────────
MODEL=claude-sonnet-4-20250514
TEMPERATURE=0
MAX_TOKENS=4096
NODE_ENV=production
FRONTEND_PORT=3000
BACKEND_PORT=3001

# ─── Redis (Persistent Sessions) ─────────────────────────────────────────────
# When set, sessions and scoped state are stored in Redis and survive restarts.
# When unset, the server falls back to in-memory storage automatically.
#
# Docker Compose sets this to redis://redis:6379 automatically.
# For local dev outside Docker, uncomment the line below:
# REDIS_URL=redis://localhost:6379

# ─── JanusGraph (Relationship Graph) ────────────────────────────────────────
# JANUSGRAPH_URL=ws://localhost:8182/gremlin
# Docker Compose sets this automatically.

# ─── Agent Framework ────────────────────────────────────────────────────────
ENABLE_UI=true
# MAX_DELEGATION_DEPTH=3
# INSTANCE_URL=http://localhost:3001
# INSTANCE_ID=

# ─── Web Search (Tavily) ─────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxx
# Get your API key at https://tavily.com

# ─── Guardrails ──────────────────────────────────────────────────────────────
# MAX_MESSAGE_LENGTH=10000       # Max characters per user message
# MAX_TOOL_CALLS=25              # Max tool calls per request (prevents infinite loops)
# REQUEST_TIMEOUT_MS=120000      # Max time per request in milliseconds (2 minutes)
# MAX_CRAWL_DEPTH=3              # Max crawl depth for web_crawl tool
# MAX_CRAWL_BREADTH=10           # Max links per page for web_crawl tool
# MAX_EXTRACT_URLS=10            # Max URLs per web_extract call
# BLOCKED_DOMAINS=localhost,127.0.0.1,0.0.0.0,169.254.169.254

# ─── MCP (Model Context Protocol) ────────────────────────────────────────────
# Connect to MCP servers to give the agent additional tools at startup.
# Provide a JSON object where each key is a server name.
#
# Example — filesystem server:
# MCP_SERVERS={"filesystem":{"transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}
#
# Alternatively, place server config in backend/mcp.json (same JSON structure).
# MCP_SERVERS=
