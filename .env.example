# ═══════════════════════════════════════════════════════════════════════════════
# Agent Scaffold — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Required API Keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Web Search (Tavily) ─────────────────────────────────────────────────────
# Required for web_search, web_extract, web_crawl, and deep_research tools.
# Get your API key at https://tavily.com
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxx

# ─── LLM Configuration ───────────────────────────────────────────────────────
# These are instance-level defaults. Individual agents can override model,
# temperature, and maxTokens via the Agent Manager UI or API.
MODEL=claude-sonnet-4-20250514
TEMPERATURE=0
MAX_TOKENS=4096

# ─── Server Configuration ────────────────────────────────────────────────────
PORT=3001                                  # Backend server port (inside container)
NODE_ENV=production                        # "development" for verbose logging
CORS_ORIGIN=http://localhost:3000          # Allowed CORS origin for frontend

# ─── Docker Compose Port Mappings ─────────────────────────────────────────────
# These control which HOST ports are exposed by Docker Compose.
FRONTEND_PORT=3000                         # Frontend UI (host:container 80)
BACKEND_PORT=3001                          # Backend API (host:container 3001)
REDIS_PORT=6379                            # Redis (host:container 6379)
JANUSGRAPH_PORT=8182                       # JanusGraph Gremlin (host:container 8182)

# ─── Redis (Persistent Storage) ──────────────────────────────────────────────
# When set, agent definitions, sessions, and scoped state are stored in Redis
# and survive restarts. When unset, falls back to in-memory storage.
#
# Docker Compose sets this to redis://redis:6379 automatically.
# For local dev outside Docker, uncomment:
# REDIS_URL=redis://localhost:6379

# ─── JanusGraph (Relationship Graph) ─────────────────────────────────────────
# Stores agent topology: Agent→Tool, Agent→Agent delegation, Agent→MCP edges.
# Falls back gracefully when not available.
#
# Docker Compose sets this automatically.
# JANUSGRAPH_URL=ws://localhost:8182/gremlin

# ─── Agent Framework ─────────────────────────────────────────────────────────
ENABLE_UI=true                             # Set to "false" to run as headless agent
# MAX_DELEGATION_DEPTH=3                   # Max agent-to-agent delegation depth

# ─── Cross-Instance Federation (Optional) ─────────────────────────────────────
# Set INSTANCE_URL to enable agents on different servers to communicate.
# Each instance registers in Redis and discovers others automatically.
# INSTANCE_URL=http://localhost:3001       # This instance's reachable URL
# INSTANCE_ID=                             # Auto-generated UUID if not set

# ─── MCP (Model Context Protocol) ────────────────────────────────────────────
# Global MCP servers loaded at startup. Per-agent MCP servers are managed
# via the Agent Manager UI or API at runtime.
#
# Provide a JSON object where each key is a server name:
# MCP_SERVERS={"filesystem":{"transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}
#
# Alternatively, place server config in backend/mcp.json.

# ─── Guardrails ──────────────────────────────────────────────────────────────
# MAX_MESSAGE_LENGTH=10000                 # Max characters per user message
# MAX_TOOL_CALLS=25                        # Max tool calls per request (prevents infinite loops)
# REQUEST_TIMEOUT_MS=120000                # Request timeout in ms (default: 2 minutes)
# MAX_CRAWL_DEPTH=3                        # Max depth for web_crawl tool
# MAX_CRAWL_BREADTH=10                     # Max links per page for web_crawl tool
# MAX_EXTRACT_URLS=10                      # Max URLs per web_extract call
# BLOCKED_DOMAINS=localhost,127.0.0.1,0.0.0.0,169.254.169.254
